<Window x:Class="Jobnet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Jobnet.ViewModels"
        mc:Ignorable="d"
        Title="Jobnet" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CompanyItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="16,10">
            <TextBlock Text="Jobnet" FontSize="20" FontWeight="Bold"/>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="Discover Companies"
                        Style="{StaticResource ToolbarButton}"
                        Command="{Binding DiscoverCompaniesCommand}"/>
                <Button Content="Refresh Jobs"
                        Style="{StaticResource ToolbarButton}"
                        Command="{Binding RefreshJobsCommand}"/>
                <Button Content="Settings"
                        Style="{StaticResource ToolbarButton}"
                        Command="{Binding OpenSettingsCommand}"
                        HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>

        <!-- Main two-pane content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Companies pane -->
            <Grid Grid.Column="0" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                    <TextBox Text="{Binding CompanySearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4"
                             BorderBrush="#CCC"
                             Tag="Search companies..."/>
                </Border>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding CompaniesView}"
                         SelectedItem="{Binding SelectedCompany}"
                         ItemContainerStyle="{StaticResource CompanyItem}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="CompanyList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CompanyViewModel}">
                            <Grid Margin="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding InterestGlyph}"
                                           FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#999"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding InterestLevel}" Value="Interesting">
                                                    <Setter Property="Foreground" Value="#F2B400"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InterestLevel}" Value="NotInteresting">
                                                    <Setter Property="Foreground" Value="#C44"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAllJobsSentinel}" Value="True">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ActiveJobCount}"
                                           Foreground="#888"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="1" Background="#DDD" HorizontalAlignment="Stretch"/>

            <!-- Jobs pane -->
            <Grid Grid.Column="2" Background="#FAFAFA">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="20,12" BorderBrush="#DDD" BorderThickness="0,0,0,1" Background="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding JobsPaneHeader}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1"
                                  Content="Show removed"
                                  IsChecked="{Binding ShowRemovedJobs}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding JobsView}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch"
                         MouseDoubleClick="JobsList_MouseDoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="16,8,16,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:JobViewModel}">
                            <Border Background="White"
                                    BorderBrush="#E5E5E5"
                                    BorderThickness="1"
                                    Padding="14,12"
                                    CornerRadius="3">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open in browser"
                                                  Command="{Binding DataContext.OpenJobInBrowserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Copy URL"
                                                  Command="{Binding DataContext.CopyJobUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="Mark Interesting (★)"
                                                  Command="{Binding DataContext.MarkJobInterestingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Mark Not Interesting (✗)"
                                                  Command="{Binding DataContext.MarkJobNotInterestingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Clear interest"
                                                  Command="{Binding DataContext.ClearJobInterestCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="Opacity" Value="0.55"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding InterestGlyph}"
                                               FontSize="13"
                                               VerticalAlignment="Top"
                                               Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#BBB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding InterestLevel}" Value="Interesting">
                                                        <Setter Property="Foreground" Value="#F2B400"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding InterestLevel}" Value="NotInteresting">
                                                        <Setter Property="Foreground" Value="#C44"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock>
                                            <Run Text="{Binding Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="14"/>
                                            <Run Text=" — " Foreground="#888"/>
                                            <Run Text="{Binding CompanyName, Mode=OneWay}" Foreground="#666"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding MetaLine}"
                                                   Foreground="#888"
                                                   FontSize="12"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="White" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="16,6">
            <TextBlock Text="{Binding StatusBarText}" Foreground="#666" FontSize="12"/>
        </Border>
    </Grid>
</Window>
