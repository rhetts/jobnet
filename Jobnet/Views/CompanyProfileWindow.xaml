<Window x:Class="Jobnet.Views.CompanyProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Company profile"
        Width="640" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="ChipPanel" TargetType="ItemsControl">
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel>
                <TextBlock Text="{Binding HeaderTitle}" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="{Binding SubHeader}" Foreground="#888" Margin="0,2,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Open website"   Command="{Binding OpenWebsiteCommand}"  Padding="8,4" Margin="0,0,8,0"/>
                    <Button Content="Open careers"   Command="{Binding OpenCareersCommand}"  Padding="8,4" Margin="0,0,8,0"/>
                    <Button Content="Generate profile" Command="{Binding RegenerateProfileCommand}" Padding="8,4"
                            Background="#1976D2" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" Padding="20,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionLabel}" Text="SUMMARY"/>
                <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" FontSize="14"/>

                <TextBlock Style="{StaticResource SectionLabel}" Text="PRODUCTS / SERVICES"/>
                <ItemsControl ItemsSource="{Binding Products}" Style="{StaticResource ChipPanel}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#E8F0FE" BorderBrush="#A4C8FF" BorderThickness="1" CornerRadius="12"
                                    Padding="10,4" Margin="0,0,6,6">
                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#1A57C2"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Style="{StaticResource SectionLabel}" Text="INDUSTRIES"/>
                <ItemsControl ItemsSource="{Binding Industries}" Style="{StaticResource ChipPanel}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="1" CornerRadius="12"
                                    Padding="10,4" Margin="0,0,6,6">
                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#444"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Style="{StaticResource SectionLabel}" Text="TECH / SIGNALS"/>
                <ItemsControl ItemsSource="{Binding TechSignals}" Style="{StaticResource ChipPanel}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFF5E0" BorderBrush="#E5B564" BorderThickness="1" CornerRadius="12"
                                    Padding="10,4" Margin="0,0,6,6">
                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#7A5810"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Style="{StaticResource SectionLabel}" Text="METADATA"/>
                <StackPanel>
                    <TextBlock>
                        <Run Text="HQ hint: " FontWeight="SemiBold" Foreground="#666"/>
                        <Run Text="{Binding Profile.HeadquartersHint, Mode=OneWay, TargetNullValue='(none)', FallbackValue='(none)'}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Size hint: " FontWeight="SemiBold" Foreground="#666"/>
                        <Run Text="{Binding Profile.SizeHint, Mode=OneWay, TargetNullValue='(none)', FallbackValue='(none)'}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding AtsLine}"     Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding CareersLine}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Margin="0,4,0,0"
                               ToolTip="30-day churn rate: % of jobs first seen 30+ days ago that are now inactive. High = roles close fast (or are pulled); low = stable board.">
                        <Run Text="Churn (30d): " FontWeight="SemiBold" Foreground="#666"/>
                        <Run Text="{Binding ChurnLine, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding GeneratedLine}" Foreground="#999" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>

                <TextBlock Style="{StaticResource SectionLabel}" Text="DISCOVERY"/>
                <StackPanel>
                    <TextBlock>
                        <Run Text="Discovered via: " FontWeight="SemiBold" Foreground="#666"/>
                        <Run Text="{Binding DiscoveryLine, Mode=OneWay}"/>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding AdditionalDiscoveryLines}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,2,0,0" Foreground="#777" FontSize="12">
                                    <Run Text="Also seen via: " FontWeight="SemiBold" Foreground="#888"/>
                                    <Run Text="{Binding Mode=OneWay}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#F4F4F4" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="14,8">
            <TextBlock Text="{Binding StatusText}" Foreground="#666" FontSize="12"/>
        </Border>
    </Grid>
</Window>
