<Window x:Class="Jobnet.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Jobnet.ViewModels"
        mc:Ignorable="d"
        Title="Jobnet — Settings"
        Width="780" Height="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
        </Style>
        <Style x:Key="TaxonomyListButton" TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="10">

            <!-- Search tab -->
            <TabItem Header="Search">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10,14,10">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Search engine"/>
                        <ComboBox SelectedValue="{Binding SearchEngine}" SelectedValuePath="Content">
                            <ComboBoxItem Content="brave_search"/>
                            <ComboBoxItem Content="google_cse"/>
                        </ComboBox>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="Brave Search is recommended — 2000 free queries/month, no site restrictions. Google CSE works but new engines can only search up to 50 specific sites as of Jan 2026."/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Brave Search API key"/>
                        <TextBox Text="{Binding BraveApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="Get a free key at https://api.search.brave.com/app/keys"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Google Custom Search API key (only if using google_cse)"/>
                        <TextBox Text="{Binding GoogleApiKey, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Google CSE engine ID (only if using google_cse)"/>
                        <TextBox Text="{Binding GoogleEngineId, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Cities to include (one per line)"/>
                        <TextBox Text="{Binding CitiesText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="140"
                                 FontFamily="Consolas"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Directories tab — manages the URL list used by directory-harvest strategies -->
            <TabItem Header="Directories">
                <Grid Margin="14,10,14,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,4,0,10">
                        <TextBlock Text="Seed URLs for the directory harvester. Each enabled row is harvested when 'Directories' is checked in the Discover companies popup. Pagination: leave the URL plain to auto-append ?page=N, or insert a literal {page} placeholder anywhere in the URL to control where the page number lands (?p={page}, /page/{page}/, &amp;offset={page}, etc)."
                                   TextWrapping="Wrap"
                                   Foreground="#666"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Add"    Command="{Binding AddDiscoverySeedCommand}"    Style="{StaticResource TaxonomyListButton}"/>
                            <Button Content="Delete" Command="{Binding DeleteDiscoverySeedCommand}" Style="{StaticResource TaxonomyListButton}"/>
                        </StackPanel>
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding DiscoverySeeds}"
                             SelectedItem="{Binding SelectedDiscoverySeed}"
                             BorderBrush="#CCC"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DiscoverySeedItemViewModel}">
                                <Border Padding="8,6" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <CheckBox Grid.Column="0" Grid.Row="0" Grid.RowSpan="4"
                                                  IsChecked="{Binding IsEnabled}"
                                                  ToolTip="Enabled — shows up in the Refresh discovery dropdown"
                                                  VerticalAlignment="Top"
                                                  Margin="0,4,10,0"/>
                                        <TextBox Grid.Column="1" Grid.Row="0"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 FontWeight="SemiBold"
                                                 Padding="4,2"
                                                 Margin="0,0,0,2"
                                                 BorderThickness="0"
                                                 Background="Transparent"/>
                                        <TextBox Grid.Column="1" Grid.Row="1"
                                                 Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Consolas" FontSize="11"
                                                 Foreground="#1976D2"
                                                 Padding="4,2"
                                                 Margin="0,0,0,2"
                                                 BorderThickness="0"
                                                 Background="Transparent"/>
                                        <TextBox Grid.Column="1" Grid.Row="2"
                                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="11"
                                                 Foreground="#666"
                                                 Padding="4,2"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="False"/>
                                        <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal" Margin="4,4,0,0">
                                            <TextBlock Text="Pages:" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBox Text="{Binding MaxPages, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="11"
                                                     Width="40"
                                                     Padding="3,1"
                                                     BorderBrush="#DDD"
                                                     ToolTip="How many pages to crawl (?page=1..N). 1 = single page; ~25 is reasonable for a paginated directory."/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Boards tab — aggregator/job-board sources, editable parallel to Directories -->
            <TabItem Header="Boards">
                <Grid Margin="14,10,14,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,4,0,10">
                        <TextBlock Text="Job-board / aggregator URLs harvested when 'Boards' is checked in the Discover companies popup. Use {page} in the URL to control where the page number goes (e.g. https://site.com/jobs?p={page}); otherwise the harvester appends ?page=N automatically."
                                   TextWrapping="Wrap"
                                   Foreground="#666"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Add"    Command="{Binding AddAggregatorCommand}"    Style="{StaticResource TaxonomyListButton}"/>
                            <Button Content="Delete" Command="{Binding DeleteAggregatorCommand}" Style="{StaticResource TaxonomyListButton}"/>
                        </StackPanel>
                    </StackPanel>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Aggregators}"
                             SelectedItem="{Binding SelectedAggregator}"
                             BorderBrush="#CCC"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AggregatorToggleViewModel}">
                                <Border Padding="8,6" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <CheckBox Grid.Column="0" Grid.Row="0" Grid.RowSpan="4"
                                                  IsChecked="{Binding IsEnabled}"
                                                  ToolTip="Enabled — included when Boards is checked in Discover companies"
                                                  VerticalAlignment="Top"
                                                  Margin="0,4,10,0"/>
                                        <TextBox Grid.Column="1" Grid.Row="0"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 FontWeight="SemiBold" Padding="4,2" Margin="0,0,0,2"
                                                 BorderThickness="0" Background="Transparent"/>
                                        <TextBox Grid.Column="1" Grid.Row="1"
                                                 Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Consolas" FontSize="11" Foreground="#1976D2"
                                                 Padding="4,2" Margin="0,0,0,2"
                                                 BorderThickness="0" Background="Transparent"/>
                                        <TextBox Grid.Column="1" Grid.Row="2"
                                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="11" Foreground="#A33" Padding="4,2"
                                                 BorderThickness="0" Background="Transparent"
                                                 TextWrapping="Wrap" AcceptsReturn="False"/>
                                        <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal" Margin="4,4,0,0">
                                            <TextBlock Text="Pages:" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBox Text="{Binding MaxPages, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="11" Width="40" Padding="3,1" BorderBrush="#DDD"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Categories tab (Levels + Areas) -->
            <TabItem Header="Categories">
                <Grid Margin="14,10,14,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Levels and Areas are the closed taxonomy used to classify jobs. Jobs map to exactly 1 level and 0+ areas. Items at the top score highest. Classification (heuristic + Claude Haiku) only maps to entries that exist here."
                               TextWrapping="Wrap"
                               Foreground="#666"
                               Margin="0,4,0,12"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Levels -->
                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top" Text="Levels" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Add"      Command="{Binding AddLevelCommand}"      Style="{StaticResource TaxonomyListButton}"/>
                                <Button Content="Delete"   Command="{Binding DeleteLevelCommand}"   Style="{StaticResource TaxonomyListButton}"/>
                                <Button Content="▲"        Command="{Binding MoveLevelUpCommand}"   Style="{StaticResource TaxonomyListButton}"/>
                                <Button Content="▼"        Command="{Binding MoveLevelDownCommand}" Style="{StaticResource TaxonomyListButton}"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Levels}"
                                     SelectedItem="{Binding SelectedLevel}"
                                     BorderBrush="#CCC">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:TaxonomyItemViewModel}">
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="4,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <!-- Areas -->
                        <DockPanel Grid.Column="2">
                            <TextBlock DockPanel.Dock="Top" Text="Areas" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Add"      Command="{Binding AddAreaCommand}"      Style="{StaticResource TaxonomyListButton}"/>
                                <Button Content="Delete"   Command="{Binding DeleteAreaCommand}"   Style="{StaticResource TaxonomyListButton}"/>
                                <Button Content="▲"        Command="{Binding MoveAreaUpCommand}"   Style="{StaticResource TaxonomyListButton}"/>
                                <Button Content="▼"        Command="{Binding MoveAreaDownCommand}" Style="{StaticResource TaxonomyListButton}"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Areas}"
                                     SelectedItem="{Binding SelectedArea}"
                                     BorderBrush="#CCC">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:TaxonomyItemViewModel}">
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="4,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Scoring tab (weights only) -->
            <TabItem Header="Scoring">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10,14,10">
                    <StackPanel>
                        <TextBlock Style="{StaticResource HintText}" TextWrapping="Wrap" Margin="0,4,0,10"
                                   Text="Area and Level scores are computed from the priority order on the Categories tab. The weights below combine them into the composite score shown in the main view."/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Score weights"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="Area weight" FontSize="11" Foreground="#666"/>
                                <TextBox Text="{Binding ScoreWeightArea, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="Level weight" FontSize="11" Foreground="#666"/>
                                <TextBox Text="{Binding ScoreWeightLevel, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- AI tab -->
            <TabItem Header="AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10,14,10">
                    <StackPanel>
                        <TextBlock Style="{StaticResource HintText}" TextWrapping="Wrap" Margin="0,4,0,10"
                                   Text="Used as a classifier fallback when the keyword heuristic doesn't match, and for company profile summarization. Provider is selected by ai_provider config; keys for unselected providers are still preserved for easy switching."/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="AI mode"/>
                        <ComboBox ItemsSource="{Binding AiModes}"
                                  SelectedItem="{Binding AiMode}"
                                  Padding="6,4"
                                  HorizontalAlignment="Left"
                                  MinWidth="160"/>
                        <TextBlock Style="{StaticResource HintText}" TextWrapping="Wrap"
                                   Text="Online = cloud chain (Gemini, then Groq on failure). Local = in-process LLamaSharp using the .gguf model below."/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Local model (.gguf)"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding LlamaModelPath, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Content="Browse..." Padding="12,4"
                                    Command="{Binding BrowseLlamaModelCommand}"/>
                        </Grid>
                        <TextBlock Style="{StaticResource HintText}" TextWrapping="Wrap"
                                   Text="Only used when AI mode = Local. Download a .gguf from Hugging Face (e.g. Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf, ~5 GB) and point at it here."/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="GPU layers" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding LlamaGpuLayers, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Style="{StaticResource HintText}" TextWrapping="Wrap"
                                           Text="0 = pure CPU (very slow). For an 8B model on a card with ≥6 GB VRAM, set to 35 (offloads every transformer layer). Drop to 20-25 if you see out-of-memory errors on first load."/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Context size" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding LlamaContextSize, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Style="{StaticResource HintText}" TextWrapping="Wrap"
                                           Text="Tokens of context. 4096 is safe for most pages; raise to 8192 if extraction prompts get truncated."/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Gemini API key"/>
                        <TextBox Text="{Binding GeminiApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="Free key at https://aistudio.google.com/apikey. Free-tier RPD is account-specific — observed as low as 20/day on flash-lite. Flash is a separate quota bucket."/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Gemini model"/>
                        <ComboBox IsEditable="True"
                                  ItemsSource="{Binding GeminiModels}"
                                  Text="{Binding GeminiModel, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Groq API key"/>
                        <TextBox Text="{Binding GroqApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="Free key at https://console.groq.com — free tier: 30 RPM, ~1K RPD for llama-3.3-70b-versatile. No credit card."/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Groq model"/>
                        <TextBox Text="{Binding GroqModel, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="Default: llama-3.3-70b-versatile (most capable). For higher RPD try llama-3.1-8b-instant."/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Claude API key"/>
                        <TextBox Text="{Binding ClaudeApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="Get a key at https://console.anthropic.com/settings/keys — paid only (no free tier)."/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Claude model"/>
                        <TextBox Text="{Binding ClaudeModel, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- AI routing tab — per-task provider override + optional local fallback. -->
            <TabItem Header="AI routing">
                <Grid Margin="14,10,14,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Foreground="#666"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Text="Pick a provider for each task. 'Default' inherits the global chain set on the AI tab. The 'Fall back to local' checkbox appends Llama to the chain so the call retries against the local model when the online provider runs out of quota."/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AiRoutingRows}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEE"
                              BorderBrush="#DDD" BorderThickness="1"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#FAFAFA"
                              RowHeight="36"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Task" Binding="{Binding Label}" Width="*" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Provider" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:AiRoutingRow}">
                                        <ComboBox ItemsSource="{Binding ProviderOptions}"
                                                  SelectedItem="{Binding Provider, UpdateSourceTrigger=PropertyChanged}"
                                                  Padding="4,2"
                                                  Margin="4,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Fall back to local Llama" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type vm:AiRoutingRow}">
                                        <CheckBox IsChecked="{Binding FallbackToLocal}"
                                                  IsEnabled="{Binding CanFallBack}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Scraping tab -->
            <TabItem Header="Scraping">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10,14,10">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Scrape delay (ms between requests)"/>
                        <TextBox Text="{Binding ScrapeDelayMs, UpdateSourceTrigger=PropertyChanged}"/>

                        <CheckBox Content="Use AI-derived selector parsers when available"
                                  IsChecked="{Binding SelectorParserEnabled}"
                                  Margin="0,16,0,0"
                                  FontWeight="SemiBold"
                                  Foreground="#333"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="When on, the first AI extraction of a company also derives a reusable CSS-selector profile. Future refreshes replay the profile instead of calling the AI — much faster. See the Parser Report screen to monitor health and override per company."/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Extraction prompt (used by Phase 7 careers-page parser)"/>
                        <TextBox Text="{Binding ClaudeExtractionPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="200"
                                 FontFamily="Consolas"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Data tab -->
            <TabItem Header="Data">
                <StackPanel Margin="14,10,14,10">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Database file"/>
                    <TextBox Text="{Binding DatabasePath, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"/>
                    <Button Content="Open data folder"
                            Command="{Binding OpenDataFolderCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Padding="10,4"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Background="#F4F4F4" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="90" Padding="6,4" Margin="0,0,8,0"/>
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Width="90" Padding="6,4"
                        IsDefault="True"
                        Background="#1976D2" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
