<Window x:Class="Jobnet.Views.RunsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Jobnet.ViewModels"
        Title="Jobnet — Runs"
        Width="980" Height="660"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FAFAFA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Run history" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Type:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox  Grid.Column="1" Width="160" Padding="6,2"
                       ItemsSource="{Binding RunTypes}"
                       SelectedItem="{Binding SelectedRunType}"/>
            <TextBlock Grid.Column="2" Text="Status:" VerticalAlignment="Center" Margin="14,0,6,0"/>
            <ComboBox  Grid.Column="3" Width="120" Padding="6,2"
                       ItemsSource="{Binding StatusOptions}"
                       SelectedItem="{Binding SelectedStatus}"/>
            <TextBlock Grid.Column="4" Text="Limit:" VerticalAlignment="Center" Margin="14,0,6,0"/>
            <TextBox   Grid.Column="5" Width="60" Padding="6,2"
                       Text="{Binding Limit, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Grid.Column="6" Text="{Binding Summary}" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#666"/>
            <Button    Grid.Column="7" Content="Refresh" Padding="14,4" Command="{Binding RefreshCommand}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Runs}"
                     SelectedItem="{Binding SelectedRun}"
                     BorderBrush="#DDD" BorderThickness="1"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:RunRow}">
                        <Border Padding="10,8" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Id, StringFormat='#{0}'}"
                                           FontFamily="Consolas" Foreground="#888" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RunType}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Status}"
                                           Foreground="{Binding StatusBrush}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Foreground="#666" FontSize="11" Margin="0,3,0,0">
                                    <Run Text="{Binding StartedDisplay, Mode=OneWay}"/>
                                    <Run Text="  ·  "/>
                                    <Run Text="{Binding DurationDisplay, Mode=OneWay}"/>
                                    <Run Text="  ·  exam "/>
                                    <Run Text="{Binding Examined, Mode=OneWay}"/>
                                    <Run Text="  add "/>
                                    <Run Text="{Binding Added, Mode=OneWay}"/>
                                    <Run Text="  upd "/>
                                    <Run Text="{Binding Updated, Mode=OneWay}"/>
                                    <Run Text="  skp "/>
                                    <Run Text="{Binding Skipped, Mode=OneWay}"/>
                                    <Run Text="  fail "/>
                                    <Run Text="{Binding Failed, Mode=OneWay}"/>
                                    <Run Text="  errs "/>
                                    <Run Text="{Binding ErrorCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Column="1" Width="1" Background="#DDD" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Margin="10,6" Foreground="#444" FontWeight="SemiBold" Text="Steps"/>
                <Grid Grid.Row="1">
                <ListBox ItemsSource="{Binding Steps}"
                         BorderBrush="#DDD" BorderThickness="1"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:StepRow}">
                            <Border Padding="10,6" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StepName}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DurationDisplay}" Foreground="#888" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="{Binding StatusBrush}" FontWeight="SemiBold"/>
                                    </Grid>
                                    <TextBlock Foreground="#666" FontSize="11" Margin="0,3,0,0">
                                        <Run Text="exam "/>
                                        <Run Text="{Binding Examined, Mode=OneWay}"/>
                                        <Run Text="  add "/>
                                        <Run Text="{Binding Added, Mode=OneWay}"/>
                                        <Run Text="  upd "/>
                                        <Run Text="{Binding Updated, Mode=OneWay}"/>
                                        <Run Text="  skp "/>
                                        <Run Text="{Binding Skipped, Mode=OneWay}"/>
                                        <Run Text="  fail "/>
                                        <Run Text="{Binding Failed, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C44" FontSize="11"
                                               Margin="0,3,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="{Binding StepsEmptyMessage}"
                           Foreground="#888" FontStyle="Italic" Padding="14,10"
                           TextWrapping="Wrap"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Steps.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                </Grid>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Close" Padding="14,4" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
