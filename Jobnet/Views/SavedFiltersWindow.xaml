<Window x:Class="Jobnet.Views.SavedFiltersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Jobnet.ViewModels"
        Title="Jobnet — Saved Filters"
        Width="560" Height="460"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FAFAFA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Manage saved filters"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Items}"
                 HorizontalContentAlignment="Stretch"
                 BorderBrush="#DDD"
                 BorderThickness="1"
                 Background="White">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:SavedFilterItem}">
                    <Border Padding="10,8" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock FontSize="10" Foreground="#888" Margin="0,2,0,0">
                                    <Run Text="created "/>
                                    <Run Text="{Binding CreatedDisplay, Mode=OneWay}"/>
                                    <Run Text="  ·  last used "/>
                                    <Run Text="{Binding UsedDisplay, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Load"
                                    Padding="10,2"
                                    Margin="6,0,4,0"
                                    Command="{Binding Parent.LoadItemCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Grid.Column="2"
                                    Content="Rename"
                                    Padding="10,2"
                                    Margin="0,0,4,0"
                                    Command="{Binding Parent.RenameItemCommand}"
                                    CommandParameter="{Binding}"/>
                            <Button Grid.Column="3"
                                    Content="Delete"
                                    Padding="10,2"
                                    Foreground="#C44"
                                    Command="{Binding Parent.DeleteItemCommand}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Padding="14,4" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
