<Window x:Class="Jobnet.Views.ParserReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Jobnet.ViewModels"
        Title="Jobnet — Parser Report"
        Width="1100" Height="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FAFAFA">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Parser report" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock Foreground="#666" FontSize="11" FontFamily="Consolas" Margin="0,2,0,0">
                <Run Text="Registered hand-written parsers: "/>
                <Run Text="{Binding RegisteredParsersDisplay, Mode=OneWay}" FontWeight="SemiBold"/>
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="System:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox  Grid.Column="1" Width="140" Padding="6,2"
                       ItemsSource="{Binding SystemFilters}"
                       SelectedItem="{Binding SelectedSystem}"/>
            <TextBlock Grid.Column="2" Text="Status:" VerticalAlignment="Center" Margin="14,0,6,0"/>
            <ComboBox  Grid.Column="3" Width="140" Padding="6,2"
                       ItemsSource="{Binding StatusFilters}"
                       SelectedItem="{Binding SelectedStatus}"/>
            <TextBlock Grid.Column="4" Text="{Binding Summary}" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#666"/>
            <Button    Grid.Column="5" Content="Refresh" Padding="14,4" Command="{Binding RefreshCommand}"/>
        </Grid>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEE"
                  BorderBrush="#DDD" BorderThickness="1"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  RowHeight="36"
                  FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Company" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Domain"  Binding="{Binding Domain}" Width="180" FontFamily="Consolas"/>
                <DataGridTextColumn Header="System"  Binding="{Binding ParserSystem}" Width="100" FontWeight="SemiBold"/>
                <!-- SortMemberPath tells DataGrid which property to sort by when the user clicks
                     the header — without it the templated column is non-sortable. -->
                <DataGridTemplateColumn Header="Status" Width="140" SortMemberPath="StatusBadge">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type vm:ParserReportRow}">
                            <Border Background="{Binding StatusBrush}"
                                    CornerRadius="3"
                                    Padding="6,2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusBadge}"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Derived"     Binding="{Binding DerivedDisplay}" Width="140"/>
                <DataGridTextColumn Header="Last result" Binding="{Binding LastResultDisplay}" Width="180"/>
                <DataGridTextColumn Header="Error" Binding="{Binding LastError}" Width="*"/>
                <DataGridTemplateColumn Header="Actions" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type vm:ParserReportRow}">
                            <Button Content="{Binding DisabledToggleLabel}"
                                    Padding="6,2"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.ToggleDisabledCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="When disabled, this company always uses AI extraction (slower) regardless of cached selectors."/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Close" Padding="14,4" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
