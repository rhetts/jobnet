<Window x:Class="Jobnet.Views.CoverLetterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jobnet — Cover Letter"
        Width="780" Height="640"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FAFAFA">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding HeaderLine}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <TabControl Grid.Row="1">
            <TabItem Header="Cover letter">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Generate"
                                Padding="14,4"
                                Margin="0,0,8,0"
                                Command="{Binding GenerateCommand}"
                                Background="#1976D2"
                                Foreground="White"/>
                        <Button Content="Copy"
                                Padding="14,4"
                                Margin="0,0,8,0"
                                Command="{Binding CopyCommand}"/>
                        <Button Content="Save to file"
                                Padding="14,4"
                                Command="{Binding SaveToFileCommand}"/>
                    </StackPanel>
                    <TextBox Grid.Row="1"
                             Text="{Binding LetterText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             Padding="8"
                             BorderBrush="#CCC"/>
                </Grid>
            </TabItem>

            <TabItem Header="Instructions">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Durable AI instructions" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <TextBlock Foreground="#666" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                   Text="Free-text guidance that's saved and applied to every cover letter generation. Examples: 'Casual tone.', 'Open with my 25 years experience.', 'Skip the cliché closing line.', 'Always sign off with Rhett (not my full name).'"/>
                        <TextBox Text="{Binding InstructionsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="200"
                                 Padding="8"
                                 BorderBrush="#CCC"/>

                        <TextBlock Text="Save folder" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <TextBlock Foreground="#666" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                   Text="Where 'Save to file' writes cover letters. The folder is created if it doesn't exist. Files are named {company}_{title}_{timestamp}.txt."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,4"
                                     BorderBrush="#CCC"
                                     FontFamily="Consolas"
                                     FontSize="11"/>
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Padding="10,4"
                                    Margin="6,0,0,0"
                                    Command="{Binding BrowseSaveDirectoryCommand}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="1"
                Padding="10,6" Margin="0,8,0,0" CornerRadius="3">
            <StackPanel>
                <TextBlock Text="{Binding StatusLine}" Foreground="#333" FontSize="12" TextWrapping="Wrap"/>
                <ProgressBar IsIndeterminate="{Binding IsBusy}"
                             Height="3" Margin="0,4,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Close" Padding="14,4" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
